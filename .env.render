# Michels Travel — Render environment template
# Configure these variables in Render Dashboard or sync them from render.yaml.
# Render provides PORT automatically, so do not set it manually in production.

NODE_ENV=production
APP_URL=https://www.michelstravel.agency
DATABASE_URL=<set via Render Postgres or your external Postgres connection string>
SESSION_SECRET=<generate_a_random_secret_with_at_least_32_characters>
ADMIN_PASSWORD=<set_a_secure_admin_password>

# GitHub OAuth
GITHUB_CLIENT_ID=<github_oauth_client_id>
GITHUB_CLIENT_SECRET=<github_oauth_client_secret>
GITHUB_CALLBACK_URL=https://www.michelstravel.agency/api/auth/github/callback

# Stripe
STRIPE_TEST_SECRET_KEY=<optional_test_secret_key>
STRIPE_TEST_PUBLISHABLE_KEY=<optional_test_publishable_key>
STRIPE_LIVE_SECRET_KEY=<stripe_live_secret_key>
STRIPE_LIVE_PUBLISHABLE_KEY=<stripe_live_publishable_key>

# Duffel
DUFFEL_API_TOKEN=<duffel_test_token>
DUFFEL_LIVE_TOKEN=<duffel_live_token>
DUFFEL_WEBHOOK_SECRET=<duffel_webhook_secret>

# OpenAI / AI integrations
AI_INTEGRATIONS_OPENAI_API_KEY=<openai_api_key>
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Email delivery
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_username>
SMTP_PASS=<smtp_password>

# Optional integrations
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_RECIPIENT_ID=
