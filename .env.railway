# ─────────────────────────────────────────────────────────────
# Michels Travel — Railway Environment Variables
# Copie estas variáveis para o painel do Railway:
# Project → Service → Variables
# ─────────────────────────────────────────────────────────────

# ── Banco de Dados (gerado automaticamente pelo Railway) ──────
# O Railway gera esta variável automaticamente ao adicionar
# o serviço PostgreSQL. NÃO precisa preencher manualmente.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Stripe ────────────────────────────────────────────────────
STRIPE_TEST_SECRET_KEY=sk_test_XXXX
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_XXXX
STRIPE_LIVE_SECRET_KEY=sk_live_XXXX
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_XXXX

# ── OpenAI / IA ───────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-XXXX
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Autenticação ──────────────────────────────────────────────
# Gere uma string aleatória segura (mínimo 32 caracteres)
SESSION_SECRET=gere_uma_string_aleatoria_segura_aqui_minimo_32_chars
ADMIN_PASSWORD=sua_senha_admin_segura

# ── URL da aplicação (preenchida automaticamente pelo Railway) ─
APP_URL=https://buyflights.net

# ── Servidor ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
