# Core application
NODE_ENV=development
PORT=5000
APP_URL=http://127.0.0.1:5000
DATABASE_URL=postgresql://user:password@host:5432/database
SESSION_SECRET=your_random_session_secret_here_minimum_32_characters
ADMIN_PASSWORD=your_secure_admin_password_here

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here
GITHUB_CALLBACK_URL=http://127.0.0.1:5000/api/auth/github/callback

# Stripe
STRIPE_TEST_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here
STRIPE_LIVE_SECRET_KEY=sk_live_your_live_secret_key_here
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here

# Duffel
DUFFEL_API_TOKEN=duffel_test_token_here
DUFFEL_LIVE_TOKEN=duffel_live_token_here
DUFFEL_WEBHOOK_SECRET=duffel_webhook_secret_here

# OpenAI / AI integrations
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Email (optional but recommended)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here

# Optional integrations
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_RECIPIENT_ID=
